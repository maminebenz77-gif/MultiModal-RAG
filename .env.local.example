# Copy to .env.local and fill in real values. Never commit .env.local itself.
# Profile: Mac dev/test — external API access allowed, dummy/non-sensitive docs only.

# --- LLM -----------------------------------------------------------------
# provider: "litellm" (any OpenAI-compatible backend) | "internal_server" (bespoke internal API)
LLM_PROVIDER=litellm
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=sk-replace-with-your-openai-key

# --- Embeddings ------------------------------------------------------------
# provider: "sentence_transformers" (local model) | "api" (remote embedding API)
EMBED_PROVIDER=sentence_transformers
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_BASE_URL=
EMBED_API_KEY=

# --- Vision ----------------------------------------------------------------
# Not wired up yet (interface exists, no concrete provider) — leave blank.
VISION_PROVIDER=
VISION_MODEL=
VISION_BASE_URL=
VISION_API_KEY=

# --- Stores ------------------------------------------------------------
# Assumes local docker-compose services.
QDRANT_URL=http://localhost:6333
ELASTIC_URL=http://localhost:9200

# --- Runtime -----------------------------------------------------------
DEVICE=auto
ALLOW_EXTERNAL=true
