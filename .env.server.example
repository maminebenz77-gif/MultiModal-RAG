# Copy to .env.server and fill in real values. Never commit .env.server itself.
# Profile: air-gapped company GPU server — no internet, real sensitive docs.
# ALLOW_EXTERNAL=false makes external calls structurally impossible (see
# multimodal_rag.providers.factory) — every base_url below must resolve to a
# loopback or private/internal address, or provider construction will raise.

# --- LLM -----------------------------------------------------------------
# provider: "litellm" if the internal gateway speaks the OpenAI-compatible
# schema, "internal_server" if it has its own bespoke request/response shape.
LLM_PROVIDER=litellm
LLM_MODEL=internal-llama-70b
LLM_BASE_URL=http://10.0.0.5:8080/v1
LLM_API_KEY=replace-with-internal-gateway-key

# --- Embeddings ------------------------------------------------------------
# Runs locally on the GPU box — no network call, no key needed.
EMBED_PROVIDER=sentence_transformers
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_BASE_URL=
EMBED_API_KEY=

# --- Vision ----------------------------------------------------------------
# Not wired up yet (interface exists, no concrete provider) — leave blank.
VISION_PROVIDER=
VISION_MODEL=
VISION_BASE_URL=
VISION_API_KEY=

# --- Stores ------------------------------------------------------------
# Internal services on the company network — must be private/internal addresses.
QDRANT_URL=http://10.0.0.6:6333
ELASTIC_URL=http://10.0.0.7:9200

# --- Runtime -----------------------------------------------------------
DEVICE=auto
ALLOW_EXTERNAL=false
